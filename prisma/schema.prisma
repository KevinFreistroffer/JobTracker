generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum ContactType {
  EMAIL
  CALL
  LINKEDIN
}

enum OpportunityStatus {
  NEW
  RESPONDED
  MEETING_SCHEDULED
  CODING_TEST
  TEST_FINISHED
  INTERVIEWING
  INTERVIEWED
  OFFER
  REJECTED
  NO_RESPONSE
  WITHDRAWN
}

model Opportunity {
  id             String             @id @default(uuid())
  contactType    ContactType?
  status         OpportunityStatus  @default(NEW)
  recruiterName  String?
  recruiterEmail String?
  companyName    String?
  roleTitle      String?
  contactDate    DateTime?
  interviewAt    DateTime?
  interviewReminderEnabled Boolean @default(false)
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model JobDescription {
  id          String   @id @default(uuid())
  companyName String
  roleTitle   String?
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
