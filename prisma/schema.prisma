generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum ContactType {
  EMAIL
  CALL
  LINKEDIN
}

enum OpportunityStatus {
  NEW
  RESPONDED
  MEETING_SCHEDULED
  CODING_TEST
  TEST_FINISHED
  INTERVIEWING
  INTERVIEWED
  OFFER
  REJECTED
  NO_RESPONSE
  WITHDRAWN
}

model Opportunity {
  id             String             @id @default(uuid())
  contactType    ContactType?
  status         OpportunityStatus  @default(NEW)
  recruiterName  String?
  recruiterEmail String?
  companyName    String?
  roleTitle      String?
  contactDate    DateTime?
  interviewAt    DateTime?
  interviewReminderEnabled Boolean @default(false)
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  jobDescription JobDescription?
}

model JobDescription {
  id                       String                      @id @default(uuid())
  opportunityId            String?                     @unique
  companyName              String
  roleTitle                String?
  body                     String                      @db.Text
  isAiRole                 Boolean                     @default(false)
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  opportunity              Opportunity?                @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  aiRequirementOccurrences AiRequirementOccurrence[]
  aiExtraction             JobDescriptionAiExtraction?
}

model AiRequirement {
  id             String                    @id @default(uuid())
  canonicalText  String                    @db.Text
  category       String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  occurrences    AiRequirementOccurrence[]
}

model AiRequirementOccurrence {
  id               String          @id @default(uuid())
  aiRequirementId  String
  jobDescriptionId String
  rawText          String          @db.Text
  createdAt        DateTime        @default(now())
  aiRequirement    AiRequirement   @relation(fields: [aiRequirementId], references: [id], onDelete: Cascade)
  jobDescription   JobDescription  @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)

  @@unique([aiRequirementId, jobDescriptionId, rawText])
}

model JobDescriptionAiExtraction {
  jobDescriptionId String         @id
  extractedAt      DateTime       @default(now())
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
}
